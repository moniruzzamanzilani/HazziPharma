@model HazziPharma.Web.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<h2 class="mb-4">📊 Dashboard</h2>

<div class="row">

    <!-- Products -->
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted mb-2">Products</h6>
                    <h2 class="fw-bold text-primary">@Model.TotalProducts</h2>
                </div>
                <div class="fs-1 text-primary">
                    <i class="bi bi-capsule-pill"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Suppliers -->
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted mb-2">Suppliers</h6>
                    <h2 class="fw-bold text-success">@Model.TotalSuppliers</h2>
                </div>
                <div class="fs-1 text-success">
                    <i class="bi bi-truck"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Purchases -->
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted mb-2">Purchases</h6>
                    <h2 class="fw-bold text-warning">@Model.TotalPurchases</h2>
                </div>
                <div class="fs-1 text-warning">
                    <i class="bi bi-cart-check"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Sales -->
   <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted mb-2">Sales</h6>
                    <h2 class="fw-bold text-danger">@Model.TotalSales</h2>
                </div>
                <div class="fs-1 text-danger">
                    <i class="bi bi-cash-stack"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">

        <!-- Today's Purchases -->
        <div class="col-xl-4 col-md-6">
            <div class="card dashboard-card shadow-sm border-0 h-100">
                <div class="card-body text-center">
                    <i class="bi bi-cart-check fs-1 text-primary"></i>
                    <h6 class="mt-3 text-muted">Today's Purchases</h6>
                    <h2 class="fw-bold text-primary">@Model.TodayPurchaseCount</h2>
                </div>
            </div>
        </div>

        <!-- Today's Sales -->
        <div class="col-xl-4 col-md-6">
            <div class="card dashboard-card shadow-sm border-0 h-100">
                <div class="card-body text-center">
                    <i class="bi bi-cash-stack fs-1 text-success"></i>
                    <h6 class="mt-3 text-muted">Today's Sales</h6>
                    <h2 class="fw-bold text-success">@Model.TodaySalesCount</h2>
                </div>
            </div>
        </div>

        <!-- Today's Purchase Amount -->
        <div class="col-xl-4 col-md-6">
            <div class="card dashboard-card shadow-sm border-0 h-100">
                <div class="card-body text-center">
                    <i class="bi bi-wallet2 fs-1 text-warning"></i>
                    <h6 class="mt-3 text-muted">Today's Purchase Amount</h6>
                    <h4 class="fw-bold text-warning">
                        ৳ @Model.TodayPurchaseAmount.ToString("N2")
                    </h4>
                </div>
            </div>
        </div>

        <!-- Today's Expense -->
        <div class="col-xl-4 col-md-6">
            <div class="card dashboard-card shadow-sm border-0 h-100">
                <div class="card-body text-center">
                    <i class="bi bi-receipt fs-1 text-danger"></i>
                    <h6 class="mt-3 text-muted">Today's Expense</h6>
                    <h4 class="fw-bold text-danger">
                        ৳ @Model.TodayExpenseAmount.ToString("N2")
                    </h4>
                </div>
            </div>
        </div>

        <!-- Today's Sales Amount -->
        <div class="col-xl-4 col-md-6">
            <div class="card dashboard-card shadow-sm border-0 h-100">
                <div class="card-body text-center">
                    <i class="bi bi-currency-dollar fs-1 text-success"></i>
                    <h6 class="mt-3 text-muted">Today's Sales Amount</h6>
                    <h4 class="fw-bold text-success">
                        ৳ @Model.TodaySalesAmount.ToString("N2")
                    </h4>
                </div>
            </div>
        </div>

        <!-- Total Expense -->
        <div class="col-xl-4 col-md-6">
            <div class="card dashboard-card shadow-sm border-0">
                <div class="card-body text-center">

                    <i class="bi bi-wallet2 fs-1 text-dark"></i>

                    <h6 class="mt-3 text-muted">
                        Total Expense Amount
                    </h6>

                    <h4 class="fw-bold text-dark">
                        ৳ @Model.TotalExpenseAmount.ToString("N2")
                    </h4>

                </div>
            </div>
        </div>

    </div>

          <div class="row mt-4">

            <!-- Low Stock -->
            <div class="col-lg-6">

                <div class="card border-danger shadow-sm h-100">

                    <div class="card-header bg-danger text-white">
                        <strong>⚠ Low Stock Medicines</strong>
                    </div>

                    <div class="card-body p-0">

                        <table class="table table-hover mb-0">

                            <thead class="table-light">
                                <tr>
                                    <th>Medicine</th>
                                    <th>Stock</th>
                                    <th>Reorder</th>
                                </tr>
                            </thead>

                            <tbody>

                                @foreach (var item in Model.LowStockProducts)
                                {
                                    <tr>
                                        <td>@item.Name</td>
                                        <td>@item.Stock</td>
                                        <td>@item.ReorderLevel</td>
                                    </tr>
                                }

                            </tbody>

                        </table>

                    </div>

                </div>

            </div>

            <!-- Expiring Soon -->
            <div class="col-lg-6">

                <div class="card border-warning shadow-sm h-100">

                    <div class="card-header bg-warning">
                        <strong>⏰ Expiring Soon</strong>
                    </div>

                    <div class="card-body p-0">

                        <table class="table table-hover mb-0">

                            <thead class="table-light">
                                <tr>
                                    <th>Medicine</th>
                                    <th>Batch</th>
                                    <th>Expiry</th>
                                </tr>
                            </thead>

                            <tbody>

                                @foreach (var item in Model.ExpiringSoonMedicines)
                                {
                                    <tr>
                                        <td>@item.Product?.Name</td>
                                        <td>@item.BatchNo</td>
                                        <td>@item.ExpiryDate?.ToString("dd-MMM-yyyy")</td>
                                    </tr>
                                }

                            </tbody>

                        </table>

                    </div>

                </div>

            </div>

   </div>  
</div>

<div class="row mt-4">

    <!-- Recent Purchases -->
    <div class="col-lg-6">

        <div class="card border-primary shadow-sm h-100">

            <div class="card-header bg-primary text-white">
                📦 Recent Purchases
            </div>

            <div class="card-body p-0">

                <table class="table table-hover mb-0">

                    <thead class="table-light">

                        <tr>
                            <th>No</th>
                            <th>Supplier</th>
                            <th class="text-end">Amount</th>
                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in Model.RecentPurchases)
                        {
                            <tr>

                                <td>@item.PurchaseNo</td>

                                <td>@item.Supplier?.Name</td>

                                <td class="text-end">
                                    ৳ @item.TotalAmount.ToString("N2")
                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

    <!-- Top Selling Medicines -->
    <div class="col-lg-6">
        <div class="card border-info shadow-sm h-100">

        <div class="card-header bg-info text-white">
            🏆 Top Selling Medicines
        </div>

            <div class="card-body p-0">

                <table class="table table-hover mb-0">

                    <thead class="table-light">

                        <tr>
                            <th>No</th>
                            <th>Medicine</th>
                            <th class="text-end">Qty Sold</th>
                        </tr>

                    </thead>

                    <tbody>

                        @{
                            int sl = 1;
                        }

                        @foreach (var item in Model.TopSellingProducts)
                        {
                            <tr>

                                <td>@sl</td>

                                <td>@item.ProductName</td>

                                <td class="text-end">
                                    @item.QuantitySold
                                </td>

                            </tr>

                            sl++;
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

<div class="row mt-4">

    <!-- Recent Sales -->
    <div class="col-lg-6">

        <div class="card border-success shadow-sm h-100">

            <div class="card-header bg-success text-white">
                💰 Recent Sales
            </div>

            <div class="card-body p-0">

                <table class="table table-hover mb-0">

                    <thead class="table-light">
                        <tr>
                            <th>Invoice</th>
                            <th>Date</th>
                            <th class="text-end">Amount</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var item in Model.RecentSales)
                        {
                            <tr>

                                <td>@item.InvoiceNo</td>

                                <td>@item.SaleDate.ToString("dd-MM-yyyy")</td>

                                <td class="text-end">
                                    ৳ @item.TotalAmount.ToString("N2")
                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

    <!-- Recent Expenses -->
    <div class="col-lg-6">

        <div class="card border-dark shadow-sm h-100">

            <div class="card-header bg-dark text-white">
                💸 Recent Expenses
            </div>

            <div class="card-body p-0">

                <table class="table table-hover mb-0">

                    <thead class="table-light">
                        <tr>
                            <th>Date</th>
                            <th>Category</th>
                            <th class="text-end">Amount</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var item in Model.RecentExpenses)
                        {
                            <tr>

                                <td>@item.ExpenseDate.ToString("dd-MM-yyyy")</td>

                                <td>@item.ExpenseCategory?.Name</td>

                                <td class="text-end">
                                    ৳ @item.Amount.ToString("N2")
                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>
 </div>
 </div>        
</div>
