@model HazziPharma.Web.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<h2 class="mb-4">📊 Dashboard</h2>

<div class="row">

    <div class="col-md-3 mb-3">
        <div class="card bg-primary text-white">
            <div class="card-body">
                <h5>Total Products</h5>
                <h2>@Model.TotalProducts</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card bg-success text-white">
            <div class="card-body">
                <h5>Total Suppliers</h5>
                <h2>@Model.TotalSuppliers</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card bg-warning text-dark">
            <div class="card-body">
                <h5>Total Purchases</h5>
                <h2>@Model.TotalPurchases</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card bg-danger text-white">
            <div class="card-body">
                <h5>Total Sales</h5>
                <h2>@Model.TotalSales</h2>
            </div>
        </div>
    </div>
    <div class="row mt-3">

        <div class="col-md-3">
            <div class="card border-primary shadow-sm">
                <div class="card-body text-center">
                    <h6 class="text-muted">Today's Purchases</h6>
                    <h3>@Model.TodayPurchaseCount</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-success shadow-sm">
                <div class="card-body text-center">
                    <h6 class="text-muted">Today's Sales</h6>
                    <h3>@Model.TodaySalesCount</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-warning shadow-sm">
                <div class="card-body text-center">
                    <h6 class="text-muted">Today's Purchase Amount</h6>
                    <h5>৳ @Model.TodayPurchaseAmount.ToString("N2")</h5>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-danger shadow-sm">
                <div class="card-body text-center">
                    <h6 class="text-muted">Today's Sales Amount</h6>
                    <h5>৳ @Model.TodaySalesAmount.ToString("N2")</h5>
                </div>
            </div>
        </div>

    </div>
</div>
<div class="row">

    <div class="col-md-6 mb-3">

        <div class="card border-danger">

            <div class="card-body">

                <h5>⚠ Low Stock Medicines</h5>

                <h2 class="text-danger">
                    @Model.LowStockCount
                </h2>

            </div>

        </div>

    </div>

    <div class="col-md-3 mb-3">

        <div class="card border-danger">

            <div class="card-body text-center">

                <h5>🚨 Expired</h5>

                <h2 class="text-danger">
                    @Model.ExpiredMedicineCount
                </h2>

            </div>

        </div>

    </div>

    <div class="col-md-3 mb-3">

        <div class="card border-warning">

            <div class="card-body text-center">

                <h5>⏰ Expiring Soon</h5>

                <h2 class="text-warning">
                    @Model.ExpiringSoonCount
                </h2>

            </div>

        </div>

    </div>
    <div class="col-md-6 mt-4">

        <div class="card border-primary">

            <div class="card-header bg-primary text-white">
                📦 Recent Purchases
            </div>

            <table class="table table-sm mb-0">

                <thead>

                    <tr>
                        <th>No</th>
                        <th>Supplier</th>
                        <th class="text-end">Amount</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model.RecentPurchases)
                    {
                        <tr>

                            <td>@item.PurchaseNo</td>

                            <td>@item.Supplier?.Name</td>

                            <td class="text-end">
                                @item.TotalAmount.ToString("0.00")
                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>
        <div class="row mt-4">

            <div class="col-md-12">

                <div class="card border-info shadow-sm">

                    <div class="card-header bg-info text-white">
                        🏆 Top Selling Medicines
                    </div>

                    <table class="table table-striped table-hover mb-0">

                        <thead>

                            <tr>
                                <th>#</th>
                                <th>Medicine Name</th>
                                <th class="text-end">Quantity Sold</th>
                            </tr>

                        </thead>

                        <tbody>

                            @{
                                int sl = 1;
                            }

                            @foreach (var item in Model.TopSellingProducts)
                            {
                                <tr>

                                    <td>@sl</td>

                                    <td>@item.ProductName</td>

                                    <td class="text-end">@item.QuantitySold</td>

                                </tr>

                                sl++;
                            }

                        </tbody>

                    </table>

                </div>

            </div>

        </div>
    </div>
    <div class="col-md-6 mt-4">

        <div class="card border-success">

            <div class="card-header bg-success text-white">
                💰 Recent Sales
            </div>

            <table class="table table-sm mb-0">

                <thead>

                    <tr>
                        <th>Invoice</th>
                        <th>Date</th>
                        <th class="text-end">Amount</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model.RecentSales)
                    {
                        <tr>

                            <td>@item.InvoiceNo</td>

                            <td>@item.SaleDate.ToString("dd-MM-yyyy")</td>

                            <td class="text-end">
                                @item.TotalAmount.ToString("0.00")
                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>
</div>
<div class="row">

    <div class="col-md-6 mb-3">
        <div class="card border-success">
            <div class="card-body">
                <h5>Total Purchase Amount</h5>
                <h3>৳ @Model.TotalPurchaseAmount.ToString("0.00")</h3>
            </div>
        </div>
    </div>

    <div class="col-md-6 mb-3">
        <div class="card border-primary">
            <div class="card-body">
                <h5>Total Sales Amount</h5>
                <h3>৳ @Model.TotalSalesAmount.ToString("0.00")</h3>
            </div>
        </div>
    </div>
    <div class="row mt-4">

        <div class="col-md-6">

            <div class="card">

                <div class="card-header bg-danger text-white">

                    <strong>⚠ Low Stock Medicines</strong>

                </div>

                <div class="card-body p-0">

                    <table class="table table-bordered mb-0">

                        <thead>

                            <tr>

                                <th>Medicine</th>

                                <th>Stock</th>

                                <th>Reorder</th>

                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var item in Model.LowStockProducts)
                            {
                                <tr>

                                    <td>@item.Name</td>

                                    <td>@item.Stock</td>

                                    <td>@item.ReorderLevel</td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

        <div class="col-md-6">

            <div class="card">

                <div class="card-header bg-warning">

                    <strong>⏰ Expiring Soon</strong>

                </div>

                <div class="card-body p-0">

                    <table class="table table-bordered mb-0">

                        <thead>

                            <tr>

                                <th>Medicine</th>

                                <th>Batch</th>

                                <th>Expiry</th>

                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var item in Model.ExpiringSoonMedicines)
                            {
                                <tr>

                                    <td>@item.Product?.Name</td>

                                    <td>@item.BatchNo</td>

                                    <td>@item.ExpiryDate?.ToString("dd-MMM-yyyy")</td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

    </div>
</div>