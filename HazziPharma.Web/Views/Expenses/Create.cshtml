@model HazziPharma.Web.Models.Expense

@{
    ViewData["Title"] = "Add Expense";
}

<h2 class="mb-4">Add Expense</h2>

<form asp-action="Create" method="post">

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="row">

        <div class="col-md-6 mb-3">

            <label class="form-label">Expense Category</label>

            <div class="d-flex align-items-start">

                <select asp-for="ExpenseCategoryId" class="form-select me-2">

                    <option value="">-- Select Category --</option>

                    @foreach (var item in ViewBag.ExpenseCategories)
                    {
                        <option value="@item.Id">@item.Name</option>
                    }

                </select>

                <a asp-controller="ExpenseCategories"
                   asp-action="Create"
                   target="_blank"
                   class="btn btn-outline-primary">
                    <i class="bi bi-plus-lg"></i>
                </a>

            </div>

            <span asp-validation-for="ExpenseCategoryId"
                  class="text-danger"></span>

        </div>

        <div class="col-md-6 mb-3">

            <label asp-for="ExpenseDate" class="form-label"></label>

            <input asp-for="ExpenseDate"
                   type="date"
                   class="form-control" />

            <span asp-validation-for="ExpenseDate"
                  class="text-danger"></span>

        </div>

    </div>

    <div class="row">

        <div class="col-md-6 mb-3">

            <label asp-for="Amount" class="form-label"></label>

            <input asp-for="Amount"
                   class="form-control"
                   placeholder="Enter Amount" />

            <span asp-validation-for="Amount"
                  class="text-danger"></span>

        </div>

        <div class="col-md-6 mb-3">

            <label asp-for="ReferenceNo" class="form-label"></label>

            <input asp-for="ReferenceNo"
                   class="form-control"
                   placeholder="Bill / Voucher No (Optional)" />

        </div>

    </div>

    <div class="mb-3">

        <label asp-for="Description" class="form-label"></label>

        <textarea asp-for="Description"
                  rows="4"
                  class="form-control"
                  placeholder="Expense Description"></textarea>

    </div>

    <button type="submit" class="btn btn-primary">
        Save Expense
    </button>

    <a asp-action="Index"
       class="btn btn-secondary">
        Back
    </a>

</form>

@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}