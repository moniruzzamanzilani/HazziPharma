@model HazziPharma.Web.Models.Expense

@{
    ViewData["Title"] = "Edit Expense";
}

<h2 class="mb-4">Edit Expense</h2>

<form asp-action="Edit" method="post">

    <input asp-for="Id" type="hidden" />

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="row">

        <div class="col-md-6 mb-3">

            <label class="form-label">Expense Category</label>

            <select asp-for="ExpenseCategoryId" class="form-select">

                <option value="">-- Select Category --</option>

                @foreach (var item in ViewBag.ExpenseCategories)
                {
                    <option value="@item.Id"
                            selected="@(item.Id == Model.ExpenseCategoryId)">
                        @item.Name
                    </option>
                }

            </select>

            <span asp-validation-for="ExpenseCategoryId"
                  class="text-danger"></span>

        </div>

        <div class="col-md-6 mb-3">

            <label asp-for="ExpenseDate" class="form-label"></label>

            <input asp-for="ExpenseDate"
                   type="date"
                   class="form-control" />

            <span asp-validation-for="ExpenseDate"
                  class="text-danger"></span>

        </div>

    </div>

    <div class="row">

        <div class="col-md-6 mb-3">

            <label asp-for="Amount" class="form-label"></label>

            <input asp-for="Amount"
                   class="form-control" />

            <span asp-validation-for="Amount"
                  class="text-danger"></span>

        </div>

        <div class="col-md-6 mb-3">

            <label asp-for="ReferenceNo" class="form-label"></label>

            <input asp-for="ReferenceNo"
                   class="form-control" />

        </div>

    </div>

    <div class="mb-3">

        <label asp-for="Description" class="form-label"></label>

        <textarea asp-for="Description"
                  rows="4"
                  class="form-control"></textarea>

    </div>

    <button type="submit" class="btn btn-primary">
        Update Expense
    </button>

    <a asp-action="Index"
       class="btn btn-secondary">
        Back
    </a>

</form>

@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}