@model HazziPharma.Web.Models.Sale

@{
    ViewData["Title"] = "Sale Details";
}
<style>

    @@media print {

        .no-print {
            display: none !important;
        }

        body {
            margin: 20px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        table th,
        table td {
            border: 1px solid black;
            padding: 6px;
        }

        h2 {
            text-align: center;
        }
    }

</style>

<div class="text-center mb-4">

    <h2 class="mb-1 fw-bold">
        Hazzi Pharma
    </h2>

    <p class="mb-0">
        South Monipur, Mirpur-2, Dhaka
    </p>

    <p class="mb-0">
        Mobile: 01303385670
    </p>

    <hr />

    <h4 class="fw-bold">
        SALES INVOICE
    </h4>

    </div>
<div class="row mb-4">

    <div class="col-6">

        <strong>Sale No</strong> :
        @Model.SaleNo

        <br />

        <strong>Invoice No</strong> :
        @Model.InvoiceNo

    </div>

    <div class="col-6 text-end">

        <strong>Date</strong> :
        @Model.SaleDate.ToString("dd-MM-yyyy")

        <br />

        <strong>Total Amount</strong> :
        @Model.TotalAmount.ToString("0.00")

    </div>

</div>
  <table class="table table-bordered">

    <thead class="table-dark">

        <tr>

            <th>Medicine</th>

            <th>Qty</th>

            <th>Price</th>

            <th>Discount</th>

            <th>Sub Total</th>

        </tr>

    </thead>

    <tbody>

        @foreach (var item in Model.SaleDetails)
        {
            <tr>

                <td>@item.Product.Name</td>

                <td>@item.Quantity</td>

                <td>@item.SalePrice.ToString("0.00")</td>

                <td>@item.Discount.ToString("0.00")</td>

                <td>@item.SubTotal.ToString("0.00")</td>

            </tr>
        }

    </tbody>

</table>

<div class="mt-3 no-print">

    <a asp-action="Index" class="btn btn-secondary">
        Back to List
    </a>

    <a asp-action="Print"
       asp-route-id="@Model.Id"
       class="btn btn-primary">
        Print Receipt
    </a>

</div>