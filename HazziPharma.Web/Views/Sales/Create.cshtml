@model HazziPharma.Web.ViewModels.SaleViewModel

@{
    ViewData["Title"] = "New Sale";
}

<h2 class="mb-4">New Sale</h2>

<form method="post">

    <div class="row">

        <div class="col-md-3">
            <label class="form-label">Sale No</label>
            <input asp-for="SaleNo" class="form-control" />
        </div>

        <div class="col-md-3">
            <label class="form-label">Sale Date</label>
            <input asp-for="SaleDate" type="date" class="form-control" />
        </div>

        <div class="col-md-3">
            <label class="form-label">Invoice No</label>
            <input asp-for="InvoiceNo" class="form-control" />
        </div>

        <div class="col-md-3">
            <label class="form-label">Remarks</label>
            <input asp-for="Remarks" class="form-control" />
        </div>

    </div>

    <hr />

    <h4>Sale Items</h4>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th width="28%">Medicine</th>
                <th width="10%">Stock</th>
                <th width="10%">Qty</th>
                <th width="12%">Sale Price</th>
                <th width="12%">Discount</th>
                <th width="12%">Sub Total</th>
                <th width="8%">Action</th>
            </tr>
        </thead>

        <tbody id="saleItems">

            <tr>

                <td>
                    <select asp-for="Items[0].ProductId"
                            asp-items="Model.Items[0].Products"
                            class="form-select">
                        <option value="">-- Select Medicine --</option>
                    </select>
                </td>

                <td>
                    <input asp-for="Items[0].Stock"
                           class="form-control stock"
                           readonly />

                    <small class="text-success stockText">
                        Available: 0
                    </small>
                </td>

               <td>
                    <input asp-for="Items[0].Quantity"
                        class="form-control qty"
                        min="1" />

                     <small class="text-danger qtyWarning"></small>
                </td>

                <td>
                    <input asp-for="Items[0].SalePrice"
                           class="form-control price" />
                </td>

                <td>
                    <input asp-for="Items[0].Discount"
                           class="form-control discount" />
                </td>

                <td>
                    <input asp-for="Items[0].SubTotal"
                           class="form-control subtotal"
                           readonly />
                </td>

                <td class="text-center">
                    <button type="button"
                            class="btn btn-danger btn-sm btnRemove">
                        ❌
                    </button>
                </td>

            </tr>

        </tbody>

    </table>

    <div class="row mt-3">
        <div class="col-md-3 offset-md-9">
            <label class="form-label fw-bold">Grand Total</label>
            <input asp-for="GrandTotal"
                   id="grandTotal"
                   class="form-control fw-bold"
                   readonly />
        </div>
    </div>

    <div class="mt-3">

        <button type="button"
                id="btnAddItem"
                class="btn btn-success">
            + Add Item
        </button>

       <button type="submit"
        name="action"
        value="save"
        class="btn btn-primary">
            Save Sale
        </button>

        <button type="submit"
                name="action"
                value="print"
                class="btn btn-warning ms-2">
            Save & Print
        </button>
    </div>

</form>

<script>

       function updateRowIndex() {

       let rows = document.querySelectorAll("#saleItems tr");

       rows.forEach(function (row, index) {

       row.querySelectorAll("input, select").forEach(function (control) {

       if (control.name) {
       control.name = control.name.replace(/Items\[\d+\]/, `Items[${index}]`);
       }

       if (control.id) {
       control.id = control.id.replace(/Items_\d+__/, `Items_${index}__`);
       }

       });

       });

       }

       function calculateGrandTotal() {

       let total = 0;

       document.querySelectorAll(".subtotal").forEach(function (item) {

       total += parseFloat(item.value) || 0;

       });

       document.getElementById("grandTotal").value = total.toFixed(2);

       }
    function calculateRow(row) {

           let qty = parseFloat(row.querySelector(".qty").value) || 0;

           let price = parseFloat(row.querySelector(".price").value) || 0;

           let discount = parseFloat(row.querySelector(".discount").value) || 0;
           
           let stock = parseFloat(row.querySelector(".stock").value) || 0;
               let warning = row.querySelector(".qtyWarning");
               if (!warning) return;
     if (qty > stock) {

        warning.innerText = "Only " + stock + " items available.";

        row.querySelector(".qty").classList.add("is-invalid");

        row.querySelector(".subtotal").value = "";

        calculateGrandTotal();

        return;
    }

       warning.innerText = "";

      row.querySelector(".qty").classList.remove("is-invalid");
           let total = (qty * price) - discount;

           if (total < 0)
               total = 0;

           row.querySelector(".subtotal").value = total.toFixed(2);

           calculateGrandTotal();

       }

       // Qty / Price / Discount Change
       document.addEventListener("input", function (e) {

           if (e.target.classList.contains("qty") ||
               e.target.classList.contains("price") ||
               e.target.classList.contains("discount")) {

               calculateRow(e.target.closest("tr"));

           }

       });

       // Add Item
       document.getElementById("btnAddItem").addEventListener("click", function () {

           let tbody = document.getElementById("saleItems");

           let firstRow = tbody.rows[0];

           let newRow = firstRow.cloneNode(true);

           newRow.querySelectorAll("input").forEach(function (input) {

               input.value = "";

           });

           newRow.querySelectorAll("select").forEach(function (select) {

               select.selectedIndex = 0;

           });

           tbody.appendChild(newRow);

           updateRowIndex();

       });

       // Remove Item
       document.addEventListener("click", function (e) {

           if (e.target.classList.contains("btnRemove")) {

               let tbody = document.getElementById("saleItems");

               if (tbody.rows.length == 1) {

                   alert("At least one item is required.");

                   return;

               }

               e.target.closest("tr").remove();

               updateRowIndex();

               calculateGrandTotal();

           }

       });
       // Product Select করলে Stock ও Sale Price Auto Load
document.addEventListener("change", async function (e) {

    if (e.target.matches("select[name*='ProductId']")) {

        let productId = e.target.value;

        if (!productId)
            return;

        let row = e.target.closest("tr");

        let response = await fetch(`/Sales/GetProductInfo?id=${productId}`);

        if (!response.ok)
            return;

        let data = await response.json();

        row.querySelector(".stock").value = data.stock;
        row.querySelector(".price").value = data.salePrice;
        row.querySelector(".stockText").innerText =
            "Available: " + data.stock;

        calculateRow(row);
    }

});
    // =========================
// CTRL + ENTER = Save & Print
// =========================
document.addEventListener("keydown", function (e) {

    if (e.ctrlKey && e.key === "Enter") {

        e.preventDefault();

        document.querySelector("button[value='print']").click();
    }

});
</script>