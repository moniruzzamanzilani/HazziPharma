@model HazziPharma.Web.Models.Sale

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Print Receipt</title>

    <style>

            @@page {
                size: 58mm auto;
                margin: 2mm;
            }

            * {
                box-sizing: border-box;
            }

            body {
                font-size: 13px;
            }

            th,
            td {
                font-size: 12px;
            }

            .shop-name {
                font-size: 22px;
            }

            .receipt {
                width: 58mm;
                margin: auto;
                padding: 3mm;
            }

            .center {
                text-align: center;
            }

            .shop-name {
                font-size: 18px;
                font-weight: bold;
            }

            .shop-info {
                font-size: 11px;
                line-height: 1.4;
            }

            hr {
                border: none;
                border-top: 1px dashed #000;
                margin: 6px 0;
            }

            table {
                width: 100%;
                border-collapse: collapse;
            }

            th,
            td {
                padding: 2px 0;
                font-size: 11px;
            }

            .right {
                text-align: right;
            }

            .footer {
                text-align: center;
                margin-top: 8px;
                font-size: 11px;
                line-height: 1.5;
            }

            @@media print {

                body {
                    margin: 0;
                }

                .receipt {
                    width: 58mm;
                }
            }

    </style>

</head>

<body onload="window.print()">

    <div class="receipt">

        <div class="center">

            <div class="shop-name">
                Hazzi Pharma
            </div>

            <div class="shop-info">
                South Monipur, Mirpur-2<br />
                Dhaka<br />
                Mobile : 01303385670
            </div>

            <hr />

            <strong>SALES RECEIPT</strong>

        </div>

        <hr />

        <table>

            <tr>
                <td>Invoice</td>
                <td class="right">@Model.InvoiceNo</td>
            </tr>

            <tr>
                <td>Sale No</td>
                <td class="right">@Model.SaleNo</td>
            </tr>

            <tr>
                <td>Date</td>
                <td class="right">
                    @Model.SaleDate.ToString("dd-MM-yyyy hh:mm tt")
                </td>
            </tr>

        </table>

        <hr />

        <table>

            <thead>

                <tr>

                    <th>Medicine</th>

                    <th class="right">Qty</th>

                    <th class="right">Total</th>

                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model.SaleDetails)
                {
                    <tr>

                        <td>@item.Product.Name</td>

                        <td class="right">@item.Quantity</td>

                        <td class="right">@item.SubTotal.ToString("0.00")</td>

                    </tr>
                }

            </tbody>

        </table>

        <hr />

        <table>

            <tr>

                <td>Total Items</td>

                <td class="right">
                    @Model.SaleDetails.Sum(x => x.Quantity)
                </td>

            </tr>

            <tr>

                <td><strong>Grand Total</strong></td>

                <td class="right">
                    <strong>@Model.TotalAmount.ToString("0.00")</strong>
                </td>

            </tr>

        </table>

        <hr />

        <div class="footer">

            <strong>Thank You</strong>

            <br />

            Visit Again

            <br /><br />

            <small>
                Medicine once sold cannot be returned.
            </small>

        </div>

    </div>

    <script>

            window.onafterprint = function () {

                window.close();

            };

    </script>

</body>

{
    <script>
        window.onload = function () {
            window.print();
        };
    </script>
}
</html>