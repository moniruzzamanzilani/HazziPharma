@model HazziPharma.Web.ViewModels.SaleReturnReportViewModel

@{
    ViewData["Title"] = "Sale Return Report";
}

<div class="text-center mb-4">

    <h2 class="mb-0">🏥 Hazzi Pharma</h2>

    <h5 class="text-secondary">Sale Return Report</h5>

    <small>
        Generated On:
        @DateTime.Now.ToString("dd-MM-yyyy hh:mm tt")
    </small>

</div>

<form method="get">

    <div class="row mb-3">

        <div class="col-md-3">
            <label>From Date</label>
            <input asp-for="FromDate" class="form-control" type="date" />
        </div>

        <div class="col-md-3">
            <label>To Date</label>
            <input asp-for="ToDate" class="form-control" type="date" />
        </div>

        <div class="col-md-3 align-self-end">

            <button type="submit" class="btn btn-primary">
                Search
            </button>

            <button type="button"
                    onclick="window.print()"
                    class="btn btn-success ms-2">
                Print
            </button>

        </div>

    </div>

</form>

<div class="mt-2 mb-2">

    <strong>Total Records:</strong>

    @Model.SaleReturns.Count()

</div>

<table class="table table-bordered table-striped">

    <thead class="table-dark">

        <tr>
            <th>Action</th>
            <th>Return No</th>
            <th>Sale No</th>
            <th>Customer</th>
            <th>Date</th>
            <th class="text-end">Return Amount</th>
        </tr>

    </thead>

    <tbody>

        @foreach (var item in Model.SaleReturns)
        {
            <tr>

                <td>
                    <a asp-controller="SaleReturns"
                       asp-action="Details"
                       asp-route-id="@item.Id"
                       class="btn btn-sm btn-info">
                        Details
                    </a>
                </td>

                <td>@item.ReturnNo</td>

                <td>@item.Sale?.SaleNo</td>

                <td>@item.Sale?.Customer?.Name</td>

                <td>@item.ReturnDate.ToString("dd-MM-yyyy")</td>

                <td class="text-end">
                    @item.TotalAmount.ToString("N2")
                </td>

            </tr>
        }

    </tbody>

    <tfoot class="table-secondary">

        <tr>

            <th colspan="5" class="text-end">
                Grand Total
            </th>

            <th class="text-end">
                @Model.TotalReturnAmount.ToString("N2")
            </th>

        </tr>

    </tfoot>

</table>