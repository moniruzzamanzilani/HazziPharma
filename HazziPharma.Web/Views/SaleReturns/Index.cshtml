@model IEnumerable<HazziPharma.Web.Models.SaleReturn>

@{
    ViewData["Title"] = "Sale Return List";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Sale Return List</h3>

    <a asp-action="Create" class="btn btn-primary">
        + New Sale Return
    </a>
</div>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Return No</th>
            <th>Return Date</th>
            <th>Sale No</th>
            <th>Total Amount</th>
            <th width="120">Action</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>@item.ReturnNo</td>

                <td>@item.ReturnDate.ToString("dd-MMM-yyyy")</td>

                <td>@item.Sale?.SaleNo</td>

                <td>@item.TotalAmount.ToString("0.00")</td>

                <td>
                    <a asp-action="Details"
                       asp-route-id="@item.Id"
                       class="btn btn-info btn-sm">
                        View
                    </a>
                </td>

            </tr>
        }

    </tbody>

</table>