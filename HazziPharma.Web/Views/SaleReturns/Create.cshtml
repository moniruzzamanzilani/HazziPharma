@model HazziPharma.Web.ViewModels.SaleReturnViewModel

@{
    ViewData["Title"] = "Sale Return";
}

<h3 class="mb-3">Sale Return</h3>

<form asp-action="Create" method="post">

    <div class="row">

        <div class="col-md-3">
            <label class="form-label">Return No</label>
            <input asp-for="ReturnNo" class="form-control" readonly />
        </div>

        <div class="col-md-3">
            <label class="form-label">Return Date</label>
            <input asp-for="ReturnDate" type="date" class="form-control" />
        </div>

        <div class="col-md-3">
            <label class="form-label">Sale</label>

            <select asp-for="SaleId"
                    asp-items="Model.Sales"
                    class="form-select">

                <option value="">-- Select Sale --</option>

            </select>

        </div>

    </div>
    <hr />

    <h5>Return Items</h5>

    <table class="table table-bordered" id="returnItems">

        <thead>

            <tr>
                <th>Medicine</th>
                <th>Sold Qty</th>
                <th>Return Qty</th>
                <th>Return Price</th>
                <th>Sub Total</th>
            </tr>

        </thead>

        <tbody>
        </tbody>

    </table>

    <div class="row">

        <div class="col-md-3 offset-md-9">
            <label>Grand Total</label>

            <input asp-for="TotalAmount"
                   class="form-control"
                   readonly />
        </div>

    </div>

    <br />

    <button class="btn btn-success">
        Save Return
    </button>
</form>
<script>
    document.getElementById("SaleId").addEventListener("change", function () {

        let saleId = this.value;

        if (!saleId) return;

        fetch("/SaleReturns/GetSaleItems?saleId=" + saleId)
            .then(response => response.json())
               .then(data => {

        let tbody = document.querySelector("#returnItems tbody");

        tbody.innerHTML = "";

        data.forEach(function (item) {

            tbody.innerHTML += `
            <tr>

                <td>${item.productName}

             <input type="hidden"
                       name="Items[${tbody.rows.length}].ProductId"
                       value="${item.productId}" />

            <input type="hidden"
                   name="Items[${tbody.rows.length}].ReturnPrice"
                   value="${item.salePrice}" />

              
                
                </td>

                <td>${item.quantity}</td>

                <td>
                    <input type="number"
                           class="form-control qty"
                           name="Items[${tbody.rows.length}].Quantity"
                           value="0">
                </td>

                <td>
                    <input type="number"
                           class="form-control price"
                           value="${item.salePrice}"
                           readonly>
                </td>

                <td>
                    <input type="number"
                           class="form-control subtotal"
                           name="Items[${tbody.rows.length}].SubTotal"
                           value="0"
                           readonly>
                </td>

            </tr>`;
        });

    });
        });document.addEventListener("change", function (e) {

        if (!e.target.classList.contains("qty"))
            return;

        let row = e.target.closest("tr");

        let qty = parseFloat(row.querySelector(".qty").value) || 0;

        let price = parseFloat(row.querySelector(".price").value) || 0;
            let soldQty = parseFloat(row.cells[1].innerText) || 0;

         if (qty > soldQty) {

            alert("Return quantity cannot exceed sold quantity.");

            let qtyBox = row.querySelector(".qty");

            qtyBox.value = 0;

            qty = 0;

            qtyBox.focus();

            qtyBox.select();
        }

        let subtotal = qty * price;

        row.querySelector(".subtotal").value = subtotal.toFixed(2);

        calculateGrandTotal();

    });

    function calculateGrandTotal() {

        let total = 0;

        document.querySelectorAll(".subtotal").forEach(function (item) {

            total += parseFloat(item.value) || 0;

        });

        document.getElementById("TotalAmount").value = total.toFixed(2);

    }
</script>