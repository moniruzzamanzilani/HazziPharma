@model HazziPharma.Web.Models.Purchase

@{
    ViewData["Title"] = "Purchase Details";
}

<h2 class="mb-3">Purchase Details</h2>

<div class="card mb-3">
    <div class="card-body">

        <div class="row">

            <div class="col-md-3">
                <strong>Purchase No:</strong><br />
                @Model.PurchaseNo
            </div>

            <div class="col-md-3">
                <strong>Date:</strong><br />
                @Model.PurchaseDate.ToString("dd-MM-yyyy")
            </div>

            <div class="col-md-3">
                <strong>Supplier:</strong><br />
                @Model.Supplier?.Name
            </div>

            <div class="col-md-3">
                <strong>Invoice No:</strong><br />
                @Model.InvoiceNo
            </div>

        </div>

    </div>
</div>

<table class="table table-bordered">

    <thead class="table-dark">

        <tr>

            <th>Medicine</th>

            <th>Purchase Price</th>

            <th>Qty</th>

            <th>Batch No</th>

            <th>Expiry Date</th>

            <th>Sub Total</th>

        </tr>

    </thead>

    <tbody>

        @foreach (var item in Model.PurchaseDetails)
        {
            <tr>

                <td>@item.Product?.Name</td>

                <td>@item.PurchasePrice.ToString("0.00")</td>

                <td>@item.Quantity</td>

                <td>@item.BatchNo</td>

                <td>@item.ExpiryDate</td>

                <td>@item.SubTotal.ToString("0.00")</td>

            </tr>
        }

    </tbody>

    <tfoot>

        <tr>

            <th colspan="5" class="text-end">
                Grand Total
            </th>

            <th>
                @Model.TotalAmount.ToString("0.00")
            </th>

        </tr>

    </tfoot>

</table>

<div class="mt-3">

    <a asp-action="Index" class="btn btn-secondary">
        Back to List
    </a>

</div>